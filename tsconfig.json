{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@config/*": [
        "tests/config/*"
      ],
      "@pages/*": [
        "tests/pages/*"
      ],
      "@utils/*": [
        "tests/utils/*"
      ],
      "@hooks/*": [
        "tests/hooks/*"
      ],
      "@types/*": [
        "tests/types/*"
      ],
      "@support/*": [
        "tests/support/*"
      ]
    },
    "lib": [
      "ES2021",
      "DOM"
    ]
  },
  "include": [
    "tests/**/*.ts",
    "cucumber.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "reports"
  ]
}